# ── .env (NEVER commit this file to GitHub) ──────────────────────────────────
# Copy this file, rename it to .env, and fill in your actual values.

# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_a_long_random_string_at_least_32_chars

# SQLite for local dev (default). For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///database.db

# Set to 'true' for local development only. NEVER true in production.
DEBUG=true
